# Base URL of the Laravel CMS API (no trailing slash).
# VITE_API_URL=http://localhost:8000
VITE_API_URL=https://alcove.whitespace.krd

# Public origin of the deployed site (no trailing slash). Drives canonical
# URLs, sitemap.xml and absolute og:image URLs. Leave unset until the real
# domain is live; canonicals then follow whatever origin serves the site.
# VITE_SITE_URL=https://www.your-domain.com
